{
  "name": "allbrew",
  "version": "0.0.3",
  "description": "Generate Homebrew formulas and casks from arbitrary URLs",
  "type": "module",
  "bin": {
    "allbrew": "./bin/allbrew.js"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "bun run bin/allbrew.ts",
    "build": "tsc --noEmit",
    "check": "tsc --noEmit",
    "release": "bun run scripts/release.ts",
    "test": "bun test tests/unit/",
    "test:watch": "bun test tests/unit/ --watch",
    "test:int": "bun test tests/integration/ --timeout 30000",
    "test:int:gate": "bun test tests/integration/ --timeout 30000 --test-name-pattern '^(?!\\[quarantine\\])'",
    "test:live-smoke": "LIVE_SMOKE=1 bun test tests/integration/live-smoke.int.test.ts --timeout 60000",
    "test:e2e": "E2E=1 bun test tests/e2e/ --timeout 300000",
    "test:e2e-heavy": "E2E_HEAVY=1 bun test tests/e2e/heavy.e2e.test.ts --timeout 600000",
    "test:e2e-tap": "E2E_TAP=1 bun run scripts/e2e-tap-local-runner.ts",
    "test:all": "bun test",
    "test:templates": "bun run scripts/test-templates.ts",
    "test:update-formulas": "bun run scripts/test-update-formulas.ts",
    "vm:init": "macos-test-harness init",
    "vm:setup": "macos-test-harness setup",
    "vm:test": "macos-test-harness run",
    "vm:test:int": "macos-test-harness run --profile integration",
    "vm:test:e2e": "macos-test-harness run --profile e2e",
    "vm:test:e2e-tap": "macos-test-harness run --profile e2e-tap",
    "vm:test:all": "macos-test-harness run --profile integration --profile e2e --profile e2e-tap",
    "vm:test:user-journeys": "macos-test-harness run --profile user-journeys",
    "vm:nightly": "macos-test-harness reset --nuclear && macos-test-harness setup && macos-test-harness run --profile user-journeys",
    "vm:readout": "macos-test-harness readout",
    "vm:reset": "macos-test-harness reset",
    "vm:reset:nuclear": "macos-test-harness reset --nuclear",
    "vm:ssh": "macos-test-harness ssh",
    "vm:sync": "macos-test-harness sync",
    "vm:clone": "macos-test-harness clone",
    "vm:teardown": "macos-test-harness teardown"
  },
  "keywords": [
    "homebrew",
    "formula",
    "cask",
    "brew",
    "tap",
    "generator"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tariqwest/allbrew.git"
  },
  "homepage": "https://github.com/tariqwest/allbrew",
  "bugs": {
    "url": "https://github.com/tariqwest/allbrew/issues"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "commander": "^13.0.0",
    "md-spreadsheet-parser": "^1.4.3",
    "octokit": "^4.0.0",
    "ora": "^8.0.0"
  },
  "optionalDependencies": {
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "macos-testing-harness": "git+https://github.com/tariqwest/macos-testing-harness.git#0e7eccf",
    "typescript": "^5.8.0"
  }
}
