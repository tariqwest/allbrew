# Optional overrides for scripts/e2e-vm-*.sh
# See .agents/plans/allbrew-e2e-lume-vm.md for the full workflow.

# LUME_VM_NAME=allbrew-e2e
# LUME_IPSW=/Users/tariqwest/Downloads/UniversalMac_26.5.2_25F84_Restore.ipsw
# LUME_VM_CPU=4
# LUME_VM_MEMORY=4GB
# LUME_VM_DISK=65GB
# LUME_VM_DISPLAY=1280x800
# LUME_SHARED_DIR=/Users/tariqwest/Developer/allbrew
# LUME_VM_USER=lume
# LUME_VM_PASSWORD=lume
# LUME_VM_SSH_KEY=$HOME/.ssh/allbrew_e2e_vm

# Optional: run the Lume VM on a remote Apple Silicon host via SSH.
# Set LUME_REMOTE_ENABLED=true to use the defaults below; leave false for local.
# LUME_REMOTE_ENABLED=false
# LUME_REMOTE_HOST=app-user@homeserver.local
# LUME_REMOTE_DIR=/Users/app-user/Developer/allbrew
# LUME_REMOTE_IPSW_DIR=/Users/app-user/Downloads
# LUME_SYNC_EXCLUDES=.git node_modules .lume .env

# E2E tap + update cycle tests (see .agents/plans/allbrew-tap-update-e2e.md)
# Set E2E_TAP=1 to enable. The fixture server and env var overrides are
# managed automatically by the test harness.
# E2E_TAP=1

# API base URL overrides (used by E2E tap tests to redirect to fixture server)
# GITHUB_API_URL=http://localhost:0/api
# NPM_REGISTRY_URL=http://localhost:0/npm
# PYPI_URL=http://localhost:0/pypi
# CRATES_URL=http://localhost:0/crates
# GO_PROXY_URL=http://localhost:0/go
# RUBYGEMS_URL=http://localhost:0/gems
# NUGET_URL=http://localhost:0/nuget
# NUGET_FLAT_URL=http://localhost:0/nuget
