# Optional overrides for the Lume macOS testing harness (bun run vm:*) and
# the legacy scripts/e2e-vm-*.sh orchestration.
#
# The harness (lume-macos-testing-harness) is consumed as a sibling file:
# dependency and configured via test-suite.ts at the repo root.
# See .agents/plans/allbrew-e2e-lume-vm.md and
# lume-macos-testing-harness/.agents/plans/allbrew-migration.md for the workflow.

# ---------------------------------------------------------------------------
# Harness project settings (TH_*)
# ---------------------------------------------------------------------------
# TH_PROJECT_NAME defaults to the basename of this repo ("allbrew").
# TH_PROJECT_USER=th-allbrew
# TH_HOST_PROJECT_DIR=/Users/$USER/Developer/allbrew
# TH_VM_WORKDIR=/Volumes/My Shared Files
# TH_VM_WORKSPACE=/Users/th-allbrew/Developer/allbrew
# TH_RUNS_DIR=/Users/$USER/Developer/allbrew/tests/e2e-runs
# TH_TEST_SUITE defaults to test-suite.ts in the project root.
# TH_EXTRA_PATH=$HOME/.bun/bin:$HOME/.local/bin:/usr/bin:/bin

# ---------------------------------------------------------------------------
# Exclusive Homebrew prefix (T0.5 / PR0b)
# ---------------------------------------------------------------------------
# Each project user owns an APFS sparsebundle that the harness attaches at
# /opt/homebrew before the e2e / e2e-tap profiles run. Disable only if you
# never run Homebrew-mutating profiles.
# TH_HOMEBREW_PREFIX_ENABLED=true
# TH_HOMEBREW_MOUNT_POINT=/opt/homebrew
# TH_HOMEBREW_LOCK_PATH=/var/run/lume-homebrew.lock
# TH_HOMEBREW_SPARSEBUNDLE_DIR=/Users/th-allbrew/Library/LumeHomebrew
# TH_HOMEBREW_SPARSEBUNDLE_NAME=homebrew.sparsebundle
# TH_HOMEBREW_SPARSEBUNDLE_SIZE_MB=16384

# ---------------------------------------------------------------------------
# Lume VM settings (LUME_*)
# ---------------------------------------------------------------------------
# LUME_VM_NAME=allbrew-e2e
# LUME_IPSW=/Users/$USER/Downloads/UniversalMac_26.5.2_25F84_Restore.ipsw
# LUME_VM_CPU=4
# LUME_VM_MEMORY=4GB
# LUME_VM_DISK=65GB
# LUME_VM_DISPLAY=1280x800
# LUME_VM_USER=lume
# LUME_VM_PASSWORD=lume

# ---------------------------------------------------------------------------
# Remote Lume host (optional)
# ---------------------------------------------------------------------------
# LUME_REMOTE_ENABLED=false
# LUME_REMOTE_HOST=app-user@homeserver.local
# LUME_REMOTE_DIR=/Users/app-user/Developer/allbrew
# LUME_REMOTE_IPSW_DIR=/Users/app-user/Downloads
# LUME_SYNC_EXCLUDES=.git node_modules .lume .env .Trashes .fseventsd .DS_Store

# ---------------------------------------------------------------------------
# E2E tap + update cycle tests (see .agents/plans/allbrew-tap-update-e2e.md)
# ---------------------------------------------------------------------------
# Set E2E_TAP=1 to enable. The fixture server and env var overrides are
# managed automatically by the test harness.
# E2E_TAP=1

# API base URL overrides (used by E2E tap tests to redirect to fixture server)
# GITHUB_API_URL=http://localhost:0/api
# NPM_REGISTRY_URL=http://localhost:0/npm
# PYPI_URL=http://localhost:0/pypi
# CRATES_URL=http://localhost:0/crates
# GO_PROXY_URL=http://localhost:0/go
# RUBYGEMS_URL=http://localhost:0/gems
# NUGET_URL=http://localhost:0/nuget
# NUGET_FLAT_URL=http://localhost:0/nuget
