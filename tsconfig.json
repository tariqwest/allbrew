{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "bin/**/*.ts",
    "lib/**/*.ts"
  ]
}
